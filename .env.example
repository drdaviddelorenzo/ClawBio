# ClawBio environment variables
# Copy to .env and fill in your keys

# FLock API — open-source model inference for intelligent routing
# Sign up at https://platform.flock.io
# Required for: Bio Orchestrator LLM routing (--provider flock)
# Not required for: all other skills (they are pure Python, no LLM needed)
FLOCK_API_KEY=your-flock-api-key-here

# Genomic Intelligence API — hosted DNA-LM inference
# https://docs.genomicintelligence.ai
# Required for: gi-promoter, gi-splice, gi-enhancer, gi-chromatin,
#               gi-expression, gi-annotation
#
# The default value below is the SHARED ClawBio hackathon key.
# Caps: 50 concurrent / 120 rpm — abuse degrades only this shared key,
# not anyone else's quota. For heavier / production use, request an
# individual key at contact@genomicintelligence.ai and replace the value.
GI_API_KEY=gi_cCtc4FLFXnh3f3NwTPUMcKIqLH7Y679L

# Override the API base URL (rarely needed — defaults to production).
# GI_BASE_URL=https://api.genomicintelligence.ai
